<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:paddingVertical="12dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:tint="@color/text"
            android:visibility="gone" />

        <TextView
            android:id="@+id/header_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Meu Player"
            android:textColor="@color/accent"
            android:textSize="22sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/count_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/muted"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg"
        app:tabMode="scrollable"
        app:tabGravity="start"
        app:tabTextColor="@color/muted"
        app:tabSelectedTextColor="@color/accent"
        app:tabIndicatorColor="@color/accent"
        app:tabRippleColor="@color/surface2">
        <com.google.android.material.tabs.TabItem android:text="Músicas" />
        <com.google.android.material.tabs.TabItem android:text="Álbuns" />
        <com.google.android.material.tabs.TabItem android:text="Artistas" />
        <com.google.android.material.tabs.TabItem android:text="Pastas" />
        <com.google.android.material.tabs.TabItem android:text="Playlists" />
    </com.google.android.material.tabs.TabLayout>

    <!-- Search -->
    <EditText
        android:id="@+id/search_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@color/surface"
        android:hint="Buscar por título ou artista..."
        android:textColorHint="@color/muted"
        android:textColor="@color/text"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:inputType="text"
        android:maxLines="1"
        android:imeOptions="actionSearch" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:padding="24dp"
        android:textColor="@color/muted"
        android:textSize="15sp"
        android:lineSpacingMultiplier="1.4"
        android:visibility="gone"
        android:text="Nenhuma música encontrada no aparelho.\n\nBaixe músicas no celular e elas aparecem aqui automaticamente." />

    <!-- Song list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/song_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <!-- Player bar -->
    <LinearLayout
        android:id="@+id/player_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface"
        android:padding="12dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/np_art"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@color/surface2"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_note" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/np_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="—" />

                <TextView
                    android:id="@+id/np_artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/muted"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:text="—" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/cur_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:text="0:00" />

            <SeekBar
                android:id="@+id/seek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent" />

            <TextView
                android:id="@+id/dur_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted"
                android:textSize="11sp"
                android:text="0:00" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp">

            <ImageButton
                android:id="@+id/btn_shuffle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_rotate"
                android:tint="@color/muted" />

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/text" />

            <ImageButton
                android:id="@+id/btn_playpause"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginHorizontal="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_play"
                android:tint="@color/accent" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="12dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_media_next"
                android:tint="@color/text" />

            <ImageButton
                android:id="@+id/btn_repeat"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_revert"
                android:tint="@color/muted" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
