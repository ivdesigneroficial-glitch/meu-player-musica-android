<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <!-- ===================== MAIN (list) ===================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp"
            android:paddingVertical="14dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_expand_more"
                android:rotation="90"
                android:tint="@color/text"
                android:visibility="gone" />

            <TextView
                android:id="@+id/header_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Meu Player"
                android:textColor="@color/accent"
                android:textSize="24sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:textStyle="bold"
                android:letterSpacing="0.01" />

            <TextView
                android:id="@+id/count_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Tabs -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg"
            app:tabMode="scrollable"
            app:tabGravity="start"
            app:tabTextColor="@color/muted"
            app:tabSelectedTextColor="@color/accent"
            app:tabIndicatorColor="@color/accent"
            app:tabIndicatorFullWidth="false"
            app:tabRippleColor="@color/surface2">
            <com.google.android.material.tabs.TabItem android:text="Músicas" />
            <com.google.android.material.tabs.TabItem android:text="Álbuns" />
            <com.google.android.material.tabs.TabItem android:text="Artistas" />
            <com.google.android.material.tabs.TabItem android:text="Pastas" />
            <com.google.android.material.tabs.TabItem android:text="Playlists" />
        </com.google.android.material.tabs.TabLayout>

        <!-- Search -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="6dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="14dp"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/search_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:hint="Buscar por título ou artista..."
                android:textColorHint="@color/muted"
                android:textColor="@color/text"
                android:paddingHorizontal="16dp"
                android:paddingVertical="12dp"
                android:drawableStart="@android:drawable/ic_menu_search"
                android:drawablePadding="10dp"
                android:drawableTint="@color/muted"
                android:inputType="text"
                android:maxLines="1"
                android:imeOptions="actionSearch" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Empty state -->
        <TextView
            android:id="@+id/empty_state"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="24dp"
            android:textColor="@color/muted"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.4"
            android:visibility="gone" />

        <!-- Song / group list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/song_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingHorizontal="8dp"
            android:paddingBottom="8dp" />

        <!-- Mini player bar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/mini_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/surface2"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="8dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        app:cardCornerRadius="10dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/mini_art"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@color/surface"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_note" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/mini_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="—" />
                        <TextView
                            android:id="@+id/mini_artist"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/muted"
                            android:textSize="12sp"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:text="—" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/mini_playpause"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_play_arrow"
                        android:tint="@color/accent" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/mini_progress"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="3dp"
                    android:progressTint="@color/accent"
                    android:progressBackgroundTint="@color/surface"
                    android:max="100"
                    android:progress="0" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- ===================== NOW PLAYING (full screen) ===================== -->
    <LinearLayout
        android:id="@+id/now_playing"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_np_gradient"
        android:padding="24dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_np_close"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_expand_more"
                android:tint="@color/text" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="TOCANDO AGORA"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:letterSpacing="0.2" />

            <ImageButton
                android:id="@+id/btn_np_add"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_playlist_add"
                android:tint="@color/text" />
        </LinearLayout>

        <!-- Big art -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="8dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp">
            <ImageView
                android:id="@+id/np_big_art"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/surface2"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_note" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Title / artist -->
        <TextView
            android:id="@+id/np_big_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@color/text"
            android:textSize="22sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/np_big_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="—"
            android:textColor="@color/muted"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Seek -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">
            <TextView
                android:id="@+id/np_cur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:text="0:00" />
            <SeekBar
                android:id="@+id/np_seek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:progressTint="@color/accent"
                android:thumbTint="@color/accent" />
            <TextView
                android:id="@+id/np_dur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:text="0:00" />
        </LinearLayout>

        <!-- Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp">

            <ImageButton
                android:id="@+id/np_shuffle"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_shuffle"
                android:tint="@color/muted" />

            <ImageButton
                android:id="@+id/np_prev"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_prev"
                android:tint="@color/text" />

            <ImageButton
                android:id="@+id/np_playpause"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_marginHorizontal="10dp"
                android:background="@drawable/bg_play_button"
                android:src="@drawable/ic_play_arrow"
                android:scaleType="centerInside"
                android:tint="@color/black" />

            <ImageButton
                android:id="@+id/np_next"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_next"
                android:tint="@color/text" />

            <ImageButton
                android:id="@+id/np_repeat"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_repeat"
                android:tint="@color/muted" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
